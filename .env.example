# ─── EMS Environment Variables ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Flask environment: development | production | testing
FLASK_ENV=development
FLASK_APP=run.py

# Secret key for session signing — CHANGE THIS in production!
SECRET_KEY=change-me-to-a-long-random-string

# SQLite database path (leave blank to use default ./ems_database.db)
DATABASE_URL=sqlite:///ems_database.db

# Server bind settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ems.log
